{
  "_meta": {
    "name": "marketing-hero",
    "description": "High-quality marketing assets with upscaling",
    "version": "1.0.0",
    "author": "comfyui-engine",
    "use_case": "Hero images for marketing, social media banners, promotional materials",
    "hardware_requirements": {
      "vram_min_gb": 16,
      "vram_recommended_gb": 16,
      "batch_limit": 2
    }
  },
  "inputs": {
    "prompt": {
      "positive": "",
      "negative": "bright colors, neon, saturated, vibrant, harsh lighting, chibi, super deformed, kawaii, uwu, meme, reaction image, waifu, girlfriend, romantic, suggestive, nsfw, explicit, low quality, worst quality, bad anatomy, bad hands, extra fingers, missing fingers, blurry, watermark, amateur, unprofessional"
    },
    "lora": {
      "name": "operator23a-v1.safetensors",
      "strength": 0.9,
      "trigger_word": "op23a"
    },
    "upscale": {
      "enabled": true,
      "factor": 2,
      "model": "4x-UltraSharp.pth",
      "denoise": 0.3
    },
    "settings": {
      "checkpoint": "ponyDiffusionV6XL.safetensors",
      "resolution": {
        "width": 1024,
        "height": 1024
      },
      "steps": 30,
      "cfg": 7,
      "sampler": "dpmpp_2m",
      "scheduler": "karras",
      "batch_size": 1,
      "seed": -1
    }
  },
  "workflow": {
    "_comment": "High-quality marketing workflow with optional upscaling pass",
    "checkpoint_loader": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": ["inputs", "settings", "checkpoint"]
      }
    },
    "lora_loader": {
      "class_type": "LoraLoader",
      "inputs": {
        "lora_name": ["inputs", "lora", "name"],
        "strength_model": ["inputs", "lora", "strength"],
        "strength_clip": ["inputs", "lora", "strength"],
        "model": ["checkpoint_loader", 0],
        "clip": ["checkpoint_loader", 1]
      }
    },
    "positive_prompt": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": ["inputs", "prompt", "positive"],
        "clip": ["lora_loader", 1]
      }
    },
    "negative_prompt": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": ["inputs", "prompt", "negative"],
        "clip": ["lora_loader", 1]
      }
    },
    "empty_latent": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": ["inputs", "settings", "resolution", "width"],
        "height": ["inputs", "settings", "resolution", "height"],
        "batch_size": ["inputs", "settings", "batch_size"]
      }
    },
    "sampler": {
      "class_type": "KSampler",
      "inputs": {
        "seed": ["inputs", "settings", "seed"],
        "steps": ["inputs", "settings", "steps"],
        "cfg": ["inputs", "settings", "cfg"],
        "sampler_name": ["inputs", "settings", "sampler"],
        "scheduler": ["inputs", "settings", "scheduler"],
        "denoise": 1,
        "model": ["lora_loader", 0],
        "positive": ["positive_prompt", 0],
        "negative": ["negative_prompt", 0],
        "latent_image": ["empty_latent", 0]
      }
    },
    "vae_decode": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["sampler", 0],
        "vae": ["checkpoint_loader", 2]
      }
    },
    "upscale_model_loader": {
      "class_type": "UpscaleModelLoader",
      "inputs": {
        "model_name": ["inputs", "upscale", "model"]
      }
    },
    "upscale_image": {
      "class_type": "ImageUpscaleWithModel",
      "inputs": {
        "upscale_model": ["upscale_model_loader", 0],
        "image": ["vae_decode", 0]
      }
    },
    "image_scale": {
      "class_type": "ImageScale",
      "inputs": {
        "image": ["upscale_image", 0],
        "upscale_method": "lanczos",
        "width": 2048,
        "height": 2048,
        "crop": "disabled"
      }
    },
    "save_image": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "marketing-hero",
        "images": ["image_scale", 0]
      }
    }
  }
}
