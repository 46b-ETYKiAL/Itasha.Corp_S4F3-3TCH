{
  "_meta": {
    "name": "manga-page-batch",
    "description": "Full manga page generation with multiple panels",
    "version": "1.0.0",
    "author": "comfyui-engine",
    "use_case": "Generate multiple panels for a complete manga page with consistent style",
    "hardware_requirements": {
      "vram_min_gb": 16,
      "vram_recommended_gb": 16,
      "batch_limit": 4
    }
  },
  "inputs": {
    "panels": [
      {
        "panel_id": "p001",
        "prompt": "",
        "pose_ref": null,
        "resolution": { "width": 768, "height": 512 }
      }
    ],
    "global_negative": "bright colors, neon, saturated, vibrant, harsh lighting, chibi, super deformed, kawaii, uwu, meme, reaction image, waifu, girlfriend, romantic, suggestive, nsfw, explicit, low quality, worst quality, bad anatomy, bad hands, extra fingers, missing fingers, blurry, watermark, 3d render, photorealistic",
    "lora": {
      "name": "operator23a-v1.safetensors",
      "strength": 0.8,
      "trigger_word": "op23a"
    },
    "consistency": {
      "style_reference": "",
      "ipadapter_strength": 0.5
    },
    "settings": {
      "checkpoint": "ponyDiffusionV6XL.safetensors",
      "steps": 25,
      "cfg": 7,
      "sampler": "dpmpp_2m",
      "scheduler": "karras",
      "base_seed": -1
    }
  },
  "workflow": {
    "_comment": "This workflow template processes panels sequentially for VRAM efficiency",
    "_execution_mode": "sequential_panels",
    "checkpoint_loader": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": ["inputs", "settings", "checkpoint"]
      }
    },
    "lora_loader": {
      "class_type": "LoraLoader",
      "inputs": {
        "lora_name": ["inputs", "lora", "name"],
        "strength_model": ["inputs", "lora", "strength"],
        "strength_clip": ["inputs", "lora", "strength"],
        "model": ["checkpoint_loader", 0],
        "clip": ["checkpoint_loader", 1]
      }
    },
    "style_image_loader": {
      "class_type": "LoadImage",
      "inputs": {
        "image": ["inputs", "consistency", "style_reference"]
      }
    },
    "ipadapter_loader": {
      "class_type": "IPAdapterModelLoader",
      "inputs": {
        "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors"
      }
    },
    "clip_vision_loader": {
      "class_type": "CLIPVisionLoader",
      "inputs": {
        "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
      }
    },
    "ipadapter_apply": {
      "class_type": "IPAdapterApply",
      "inputs": {
        "ipadapter": ["ipadapter_loader", 0],
        "clip_vision": ["clip_vision_loader", 0],
        "image": ["style_image_loader", 0],
        "model": ["lora_loader", 0],
        "weight": ["inputs", "consistency", "ipadapter_strength"]
      }
    },
    "negative_prompt": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": ["inputs", "global_negative"],
        "clip": ["lora_loader", 1]
      }
    },
    "_panel_template": {
      "_comment": "This template is repeated for each panel",
      "positive_prompt": {
        "class_type": "CLIPTextEncode",
        "inputs": {
          "text": ["panel", "prompt"],
          "clip": ["lora_loader", 1]
        }
      },
      "empty_latent": {
        "class_type": "EmptyLatentImage",
        "inputs": {
          "width": ["panel", "resolution", "width"],
          "height": ["panel", "resolution", "height"],
          "batch_size": 1
        }
      },
      "sampler": {
        "class_type": "KSampler",
        "inputs": {
          "seed": ["panel", "seed"],
          "steps": ["inputs", "settings", "steps"],
          "cfg": ["inputs", "settings", "cfg"],
          "sampler_name": ["inputs", "settings", "sampler"],
          "scheduler": ["inputs", "settings", "scheduler"],
          "denoise": 1,
          "model": ["ipadapter_apply", 0],
          "positive": ["positive_prompt", 0],
          "negative": ["negative_prompt", 0],
          "latent_image": ["empty_latent", 0]
        }
      },
      "vae_decode": {
        "class_type": "VAEDecode",
        "inputs": {
          "samples": ["sampler", 0],
          "vae": ["checkpoint_loader", 2]
        }
      },
      "save_image": {
        "class_type": "SaveImage",
        "inputs": {
          "filename_prefix": ["panel", "panel_id"],
          "images": ["vae_decode", 0]
        }
      }
    }
  }
}
