{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "flux2-dev.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "FluxGuidance",
    "inputs": {
      "guidance": 1.0,
      "conditioning": ["2", 0]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{control_image}}"
    }
  },
  "5": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "flux-controlnet-union-pro.safetensors"
    }
  },
  "6": {
    "class_type": "SetUnionControlNetType",
    "inputs": {
      "control_net": ["5", 0],
      "type": "{{control_type}}"
    },
    "_meta": {
      "note": "control_type: canny, depth, hed, openpose, scribble, tile, blur, gray, low_quality"
    }
  },
  "7": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["3", 0],
      "negative": ["3", 0],
      "control_net": ["6", 0],
      "image": ["4", 0],
      "strength": 0.85,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 42,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["7", 1],
      "latent_image": ["8", 0]
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "flux-controlnet",
      "images": ["10", 0]
    }
  }
}
