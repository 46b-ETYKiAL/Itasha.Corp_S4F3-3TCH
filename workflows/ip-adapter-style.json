{
  "_meta": {
    "name": "ip-adapter-style",
    "description": "IP-Adapter style transfer for consistent visual style application",
    "version": "1.0.0",
    "author": "comfyui-engine",
    "use_case": "Apply style from a reference image to new generations using IP-Adapter",
    "hardware_requirements": {
      "vram_min_gb": 10,
      "vram_recommended_gb": 16,
      "batch_limit": 2
    }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["20", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ponyDiffusionV6XL.safetensors"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["4", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["4", 1]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["4", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "ipadapter_style",
      "images": ["8", 0]
    }
  },
  "11": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{STYLE_REF_IMAGE}}"
    }
  },
  "20": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["4", 0],
      "preset": "PLUS (high strength)",
      "ipadapter": null
    }
  },
  "21": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["20", 0],
      "ipadapter": ["20", 1],
      "image": ["11", 0],
      "weight": 0.7,
      "weight_type": "style transfer",
      "start_at": 0.0,
      "end_at": 0.9,
      "clip_vision": ["20", 2]
    }
  }
}
