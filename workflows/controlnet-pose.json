{
  "_meta": {
    "name": "controlnet-pose",
    "description": "ControlNet OpenPose-guided generation for character poses",
    "version": "1.0.0",
    "author": "comfyui-engine",
    "use_case": "Pose-controlled character generation using OpenPose preprocessor and ControlNet",
    "hardware_requirements": {
      "vram_min_gb": 10,
      "vram_recommended_gb": 16,
      "batch_limit": 2
    }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["4", 0],
      "positive": ["15", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ponyDiffusionV6XL.safetensors"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["4", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["4", 1]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["4", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "controlnet_pose",
      "images": ["8", 0]
    }
  },
  "11": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{POSE_IMAGE}}"
    }
  },
  "12": {
    "class_type": "OpenPosePreprocessor",
    "inputs": {
      "image": ["11", 0],
      "detect_hand": true,
      "detect_body": true,
      "detect_face": true,
      "resolution": 1024
    }
  },
  "13": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control_v11p_sd15_openpose_fp16.safetensors"
    }
  },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["13", 0],
      "image": ["12", 0],
      "strength": 0.85,
      "start_percent": 0.0,
      "end_percent": 0.9
    }
  },
  "15": {
    "_note": "ControlNet positive conditioning output",
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["13", 0],
      "image": ["12", 0],
      "strength": 0.85,
      "start_percent": 0.0,
      "end_percent": 0.9
    }
  }
}
