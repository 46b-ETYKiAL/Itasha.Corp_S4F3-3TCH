      "model": ["1", 0],
      "weight": 0.8,
      "noise": 0.0,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "7": {
    "class_type": "IPAdapterApply",
    "inputs": {
      "ipadapter": null,
      "clip_vision": null,
      "image": ["5", 0],
      "model": ["6", 0],
